# Database
DB_NAME=innerorbit_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# OpenAI
OPENAI_API_KEY=sk-...

# Admin Account (단일 관리자 계정)
# 운영 환경에서는 반드시 강력한 비밀번호로 변경하세요.
# ADMIN_PASSWORD에 BCrypt hash 값도 사용 가능 ($ 로 시작하는 $2a$... 형식)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here

# JWT Secret (최소 32자 이상의 랜덤 문자열)
# 생성 예시: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long_replace_this
